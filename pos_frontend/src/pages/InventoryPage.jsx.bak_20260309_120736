          </div>
          <button onClick={onClose} className="text-gray-400 hover:text-gray-700 font-black text-xl">✕</button>
        </div>

        {/* Stats bar */}
        <div className="grid grid-cols-3 divide-x divide-x-reverse border-b">
          <div className="px-4 py-3 text-center">
            <div className="text-lg font-black text-blue-700">{totalItems}</div>
            <div className="text-xs text-gray-400">صنف</div>
          </div>
          <div className="px-4 py-3 text-center">
            <div className="text-lg font-black text-green-600">{totalReceived}</div>
            <div className="text-xs text-gray-400">مستلم</div>
          </div>
          <div className="px-4 py-3 text-center">
            <div className="text-lg font-black text-gray-700">{Number(order.total_cost||0).toFixed(2)} ج</div>
            <div className="text-xs text-gray-400">الإجمالي</div>
