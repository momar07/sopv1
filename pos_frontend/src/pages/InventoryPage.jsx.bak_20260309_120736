        {/* Tabs */}
        <div className="flex border-b px-5">
          {[{key:'details',label:'📋 البنود'},{key:'receive',label:'📥 استلام'}].map(t=>(
            <button key={t.key} onClick={()=>setTab(t.key)}
              className={`px-4 py-3 text-sm font-bold border-b-2 transition -mb-px ${
                tab===t.key?'border-blue-600 text-blue-600':'border-transparent text-gray-500 hover:text-gray-700'
              }`}>{t.label}</button>
          ))}
        </div>

        {/* Content */}
        <div className="flex-1 overflow-y-auto p-5">

          {/* تاب البنود */}
          {tab === 'details' && (
            <table className="w-full text-sm">
              <thead>
                <tr className="bg-gray-50 text-gray-500 text-right">
                  <th className="px-3 py-2 font-bold">المنتج</th>
                  <th className="px-3 py-2 font-bold text-center">الكمية المطلوبة</th>
                  <th className="px-3 py-2 font-bold text-center">المستلم</th>
                  <th className="px-3 py-2 font-bold text-center">المتبقي</th>
                  <th className="px-3 py-2 font-bold text-center">تكلفة الوحدة</th>
                  <th className="px-3 py-2 font-bold text-center">الإجمالي</th>
                </tr>
              </thead>
              <tbody>
                {(order.items||[]).map(it=>(
                  <tr key={it.id} className="border-t hover:bg-gray-50">
                    <td className="px-3 py-2 font-bold">{it.product_name}</td>
                    <td className="px-3 py-2 text-center font-bold">{it.quantity}</td>
                    <td className="px-3 py-2 text-center text-green-600 font-bold">{it.received_quantity||0}</td>
