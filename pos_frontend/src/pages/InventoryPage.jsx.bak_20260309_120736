                  ))}
                </tbody>
              </table>
              {order.notes && (
                <div className="bg-gray-50 border border-gray-200 rounded-xl px-3 py-2 text-xs text-gray-500">
                  📝 {order.notes}
                </div>
              )}
            </div>
          )}
        </div>

        {/* Footer */}
        <div className="px-5 py-4 border-t flex gap-3">
          {tab === 'details' ? (
            <>
              <button onClick={()=>setTab('receive')}
                className="flex-1 bg-green-600 hover:bg-green-700 text-white font-bold py-2 rounded-xl text-sm flex items-center justify-center gap-2">
                <i className="fas fa-box-open"></i> الانتقال للاستلام
